{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "frontend",
      "runtimeExecutable": "/usr/local/bin/node",
      "runtimeArgs": ["/usr/local/bin/npx", "react-scripts", "start"],
      "port": 3000,
      "cwd": "frontend",
      "env": {
        "PATH": "/usr/local/bin:/usr/bin:/bin"
      }
    },
    {
      "name": "backend",
      "runtimeExecutable": "/usr/local/bin/node",
      "runtimeArgs": ["server.js"],
      "port": 5001,
      "cwd": "backend",
      "env": {
        "PATH": "/usr/local/bin:/usr/bin:/bin"
      }
    }
  ]
}
